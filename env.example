# ─────────────────────────────────────────────────────────────
# QuadraticVote environment configuration
# Copy to .env.local and fill in. Only the variables below are read
# by the app today.
# ─────────────────────────────────────────────────────────────

# Supabase
# ========
# Project settings > API. The service-role key is server-only and must
# never be exposed to the browser.
NEXT_PUBLIC_SUPABASE_URL="https://[YOUR-PROJECT-REF].supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="[YOUR-ANON-KEY]"
SUPABASE_SERVICE_ROLE_KEY="[YOUR-SERVICE-ROLE-KEY]"

# Email (Resend) — optional
# =========================
# Without these, invite emails are skipped gracefully and admins share
# invite links manually.
RESEND_API_KEY="[YOUR-RESEND-API-KEY]"
FROM_EMAIL="noreply@yourdomain.com"

# Application
# ===========
# Public base URL. Also used to scope CORS and the CSP connect-src.
NEXT_PUBLIC_APP_URL="http://localhost:3000"
